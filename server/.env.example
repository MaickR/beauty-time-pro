# ─────────────────────────────────────────────────────────────────
# Beauty Time Pro — Variables de entorno del SERVIDOR (Fastify)
# Copia este archivo a server/.env y completa los valores reales.
# NUNCA subas server/.env al repositorio.
# ─────────────────────────────────────────────────────────────────

# ── Base de datos ──────────────────────────────────────────────
DATABASE_URL=mysql://usuario:contraseña@host:3306/beauty_time_pro

# ── JWT ────────────────────────────────────────────────────────
# Mínimo 32 caracteres aleatorios. Generar con: openssl rand -base64 32
JWT_SECRETO=cambia_esto_por_un_secreto_seguro_de_al_menos_32_chars

JWT_EXPIRA_EN=15m
JWT_REFRESH_EXPIRA_EN=7d

# ── Notificaciones push (VAPID) ────────────────────────────────
# Generar con: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ── Email transaccional (Resend) ───────────────────────────────
# Requerido en producción. Obtener en https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_REMITENTE=notificaciones@beautytimepro.com

# ── URLs ────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Servidor ───────────────────────────────────────────────────
PUERTO=3000
ENTORNO=development

# ── Administración ─────────────────────────────────────────────
# Coma-separado de emails protegidos (no se pueden eliminar desde la app)
ADMINS_PROTEGIDOS=miguel@beautytimepro.com

# Clave maestra opcional para crear cuentas maestro sin invitación
# Mínimo 12 caracteres. Si se omite, la creación de maestros queda deshabilitada.
CLAVE_MAESTRO=

# Clave de acceso a cuentas demo de dueño (solo para entornos de demo)
DEMO_CLAVE_DUENO=

# ── Script de semilla (npm run semilla) ────────────────────────
# Contraseñas para los administradores maestros creados por el script.
# Si se omiten, se usan los valores por defecto definidos en scripts/semilla.ts.
ADMIN_PRINCIPAL_CONTRASENA=
ADMIN_SECUNDARIO_CONTRASENA=
