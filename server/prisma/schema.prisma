// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum EstadoSalon {
  pendiente
  aprobado
  rechazado
  suspendido
  bloqueado
}

enum PlanEstudio {
  STANDARD
  PRO
}

enum RolUsuario {
  maestro
  supervisor
  vendedor
  dueno
  empleado
}

// ─────────────────────────────────────────
// Modelos de dominio — Beauty Time Pro
// ─────────────────────────────────────────

model Estudio {
  id                String       @id @default(cuid())
  nombre            String
  propietario       String
  telefono          String
  sitioWeb          String?
  pais              String       @default("Mexico")
  zonaHoraria       String       @default("America/Mexico_City")
  sucursales        Json         // string[]
  estudioPrincipalId String?
  claveDueno           String       @unique
  claveCliente         String       @unique
  slug                 String?      @unique
  activo               Boolean      @default(true)
  permiteReservasPublicas Boolean   @default(true)
  plan                 PlanEstudio  @default(STANDARD)
  pinCancelacionHash   String?
  estado            EstadoSalon  @default(pendiente)
  motivoRechazo     String?
  motivoBloqueo     String?
  fechaSolicitud    DateTime     @default(now())
  fechaAprobacion   DateTime?
  fechaSuspension   DateTime?
  fechaBloqueo      DateTime?
  suscripcion       String       @default("mensual")
  inicioSuscripcion String       // "YYYY-MM-DD"
  fechaVencimiento  String       // "YYYY-MM-DD"
  precioPlanActualId        String?
  precioPlanProximoId       String?
  fechaAplicacionPrecioProximo String?
  horario           Json         // Record<string, TurnoTrabajo>
  servicios         Json         // Servicio[]
  serviciosCustom   Json         // ServicioPersonalizado[]
  festivos          Json         // string[] fechas bloqueadas
  excepcionesDisponibilidad Json? // Excepciones por fecha/sede para cierres y horarios modificados
  metodosPagoReserva Json?      // MetodoPagoReserva[] habilitados por el salon
  colorPrimario     String?      @default("#C2185B")
  logoUrl           String?
  descripcion       String?
  direccion         String?
  emailContacto     String?
  horarioApertura   String?      @default("09:00")
  horarioCierre     String?      @default("18:00")
  diasAtencion      String?      @default("lunes,martes,miercoles,jueves,viernes")
  numeroEspecialistas Int?       @default(1)
  categorias        String?
  primeraVez        Boolean      @default(true)
  cancelacionSolicitada     Boolean   @default(false)
  fechaSolicitudCancelacion DateTime?
  motivoCancelacion         String?
  vendedorAsociado  String?
  vendedorId        String?
  creadoEn          DateTime     @default(now())
  actualizadoEn     DateTime     @updatedAt

  estudioPrincipal  Estudio?     @relation("JerarquiaSedes", fields: [estudioPrincipalId], references: [id], onDelete: SetNull)
  sedes             Estudio[]    @relation("JerarquiaSedes")
  vendedor          Usuario?     @relation("EstudioVendedor", fields: [vendedorId], references: [id])
  precioPlanActual  PrecioPlan?  @relation("PrecioPlanActual", fields: [precioPlanActualId], references: [id], onDelete: SetNull)
  precioPlanProximo PrecioPlan?  @relation("PrecioPlanProximo", fields: [precioPlanProximoId], references: [id], onDelete: SetNull)
  personal          Personal[]
  reservas          Reserva[]
  pagos             Pago[]
  diasFestivos      DiaFestivo[]
  usuarios          Usuario[]
  clientes          Cliente[]
  configFidelidad   ConfigFidelidad?
  puntosFidelidad   PuntosFidelidad[]
  notificaciones    NotificacionEstudio[]
  mensajesMasivos   MensajeMasivo[]
  productos         Producto[]
  mensajesMasivosUsados Int       @default(0)
  mensajesMasivosExtra  Int       @default(0)

  @@map("estudios")
  @@index([estado, activo])
  @@index([pais, estado])
  @@index([fechaVencimiento])
  @@index([vendedorAsociado])
  @@index([vendedorId])
  @@index([estudioPrincipalId])
  @@index([estudioPrincipalId, estado, activo])
  @@index([precioPlanActualId])
  @@index([precioPlanProximoId])
}

model PrecioPlan {
  id          String      @id @default(uuid())
  plan        PlanEstudio
  pais        String
  moneda      String
  monto       Int
  version     Int
  vigenteDesde DateTime   @default(now())
  creadoEn    DateTime    @default(now())
  actualizadoEn DateTime  @updatedAt

  estudiosActuales Estudio[] @relation("PrecioPlanActual")
  estudiosProximos Estudio[] @relation("PrecioPlanProximo")

  @@map("precios_plan")
  @@unique([plan, pais, version])
  @@index([plan, pais, vigenteDesde])
}

// ─── Preregistro de salón por vendedor ──────────────────
model PreregistroSalon {
  id                String   @id @default(cuid())
  vendedorId        String
  vendedor          Usuario  @relation(fields: [vendedorId], references: [id])

  // Datos del salón
  nombreSalon       String
  propietario       String
  emailPropietario  String
  telefonoPropietario String
  pais              String   @default("Mexico")
  direccion         String?
  descripcion       String?  @db.Text
  categorias        String?
  plan              PlanEstudio @default(STANDARD)

  // Estado
  estado            String   @default("pendiente")  // pendiente | aprobado | rechazado
  motivoRechazo     String?  @db.Text
  estudioCreadoId   String?  // ID del estudio generado al aprobar
  notas             String?  @db.Text

  creadoEn          DateTime @default(now())
  actualizadoEn     DateTime @updatedAt

  @@map("preregistros_salon")
  @@index([vendedorId])
  @@index([estado])
}

model ClienteApp {
  id                String      @id @default(uuid())
  email             String      @unique
  emailPendiente    String?
  hashContrasena    String
  nombre            String
  apellido          String
  fechaNacimiento   DateTime?
  pais              String      @default("Mexico")
  telefono          String?     @unique
  ciudad            String?
  avatarUrl         String?
  emailVerificado   Boolean     @default(false)
  activo            Boolean     @default(true)
  ultimoAcceso      DateTime?
  creadoEn          DateTime    @default(now())
  actualizadoEn     DateTime    @updatedAt

  tokens            TokenVerificacionApp[]
  reservas          Reserva[]
  suscripcionesPush SuscripcionPush[]

  @@map("clientes_app")
  @@index([pais])
}

model TokenVerificacionApp {
  id          String      @id @default(uuid())
  token       String      @unique @default(uuid())
  tipo        String      // "verificacion_email" | "reset_contrasena"
  codigoHash  String?
  usuarioId   String?
  clienteId   String?
  clienteApp  ClienteApp? @relation(fields: [clienteId], references: [id])
  expiraEn    DateTime
  usado       Boolean     @default(false)
  ultimoEnvioEn DateTime   @default(now())
  intentosFallidos Int     @default(0)
  creadoEn    DateTime    @default(now())

  @@map("tokens_verificacion_app")
  @@index([clienteId, tipo, usado, expiraEn])
}

model SesionAutenticacion {
  id               String   @id @default(uuid())
  sujetoTipo       String
  sujetoId         String
  refreshTokenHash String
  csrfTokenHash    String
  userAgent        String?
  ip               String?
  expiraEn         DateTime
  ultimoUsoEn      DateTime @default(now())
  revocadaEn       DateTime?
  motivoRevocacion String?
  creadaEn         DateTime @default(now())
  actualizadaEn    DateTime @updatedAt

  @@map("sesiones_autenticacion")
  @@index([sujetoTipo, sujetoId, revocadaEn])
  @@index([expiraEn])
}

model CorreoPendiente {
  id          String   @id @default(cuid())
  destinatario String
  asunto      String
  html        String   @db.Text
  estado      String   @default("pending")
  intentos    Int      @default(0)
  maxIntentos Int      @default(5)
  ultimoError String?  @db.Text
  procesarEn  DateTime @default(now())
  enviadoEn   DateTime?
  tipoEvento  String?
  referenciaId String?
  claveUnica  String?  @unique
  creadoEn    DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@map("correos_pendientes")
  @@index([estado, procesarEn])
  @@index([tipoEvento, referenciaId])
}

model Personal {
  id             String    @id @default(cuid())
  estudioId      String
  nombre         String
  avatarUrl      String?
  especialidades Json      // string[]
  activo         Boolean   @default(true)
  eliminadoEn    DateTime?
  horaInicio     String?   // "HH:mm"
  horaFin        String?   // "HH:mm"
  descansoInicio String?   // "HH:mm"
  descansoFin    String?   // "HH:mm"
  diasTrabajo    Json?     // number[] (0=Dom…6=Sab) | null usa horario del estudio
  creadoEn       DateTime  @default(now())

  estudio        Estudio        @relation(fields: [estudioId], references: [id], onDelete: Cascade)
  reservas       Reserva[]
  acceso         EmpleadoAcceso?

  @@map("personal")
  @@index([estudioId, activo])
}

model EmpleadoAcceso {
  id             String    @id @default(uuid())
  personalId     String    @unique
  personal       Personal  @relation(fields: [personalId], references: [id], onDelete: Cascade)
  email          String    @unique
  hashContrasena String
  forzarCambioContrasena Boolean @default(false)
  activo         Boolean   @default(true)
  ultimoAcceso   DateTime?
  creadoEn       DateTime  @default(now())
  actualizadoEn  DateTime  @updatedAt

  @@map("empleados_acceso")
}

model Cliente {
  id              String    @id @default(uuid())
  estudioId       String
  estudio         Estudio   @relation(fields: [estudioId], references: [id], onDelete: Cascade)
  nombre          String
  telefono        String
  fechaNacimiento DateTime
  email           String?
  notas           String?   @db.Text
  activo          Boolean   @default(true)
  creadoEn        DateTime  @default(now())
  actualizadoEn   DateTime  @updatedAt

  reservas        Reserva[]
  puntosFidelidad PuntosFidelidad[]

  @@unique([estudioId, telefono])
  @@map("clientes")
}

model ConfigFidelidad {
  id                     String   @id @default(uuid())
  estudioId              String   @unique
  estudio                Estudio  @relation(fields: [estudioId], references: [id], onDelete: Cascade)
  activo                 Boolean  @default(false)
  visitasRequeridas      Int      @default(5)
  tipoRecompensa         String   @default("descuento") // descuento | servicio_gratis
  porcentajeDescuento    Int?     @default(100)
  descripcionRecompensa  String   @default("Servicio gratis en tu próxima visita")
  creadoEn               DateTime @default(now())
  actualizadoEn          DateTime @updatedAt

  @@map("config_fidelidad")
}

model PuntosFidelidad {
  id                  String   @id @default(uuid())
  clienteId           String
  cliente             Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  estudioId           String
  estudio             Estudio  @relation(fields: [estudioId], references: [id], onDelete: Cascade)
  visitasAcumuladas   Int      @default(0)
  visitasUsadas       Int      @default(0)
  recompensasGanadas  Int      @default(0)
  recompensasUsadas   Int      @default(0)
  ultimaVisita        DateTime?
  creadoEn            DateTime @default(now())
  actualizadoEn       DateTime @updatedAt

  @@unique([clienteId, estudioId])
  @@map("puntos_fidelidad")
}

model Reserva {
  id              String   @id @default(cuid())
  estudioId       String
  personalId      String
  clienteId       String
  nombreCliente   String
  telefonoCliente String
  fecha           String   // "YYYY-MM-DD"
  horaInicio      String   // "HH:mm"
  duracion        Int      // minutos
  servicios       Json     // Servicio[]
  precioTotal     Int      @default(0)
  estado          String   @default("pending") // pending | confirmed | completed | cancelled
  sucursal        String   @default("")
  marcaTinte      String?
  tonalidad       String?
  notasMenorEdad  String?
  clienteAppId    String?
  recordatorioEnviado Boolean @default(false)
  tokenCancelacion   String @unique @default(uuid())
  observaciones      String? @db.Text
  metodoPago         String?
  motivoCancelacion  String?
  productosAdicionales Json?
  reagendada         Boolean @default(false)
  reservaOriginalId String?
  creadoEn        DateTime @default(now())

  estudio         Estudio     @relation(fields: [estudioId], references: [id], onDelete: Cascade)
  empleado        Personal    @relation(fields: [personalId], references: [id], onDelete: Restrict)
  cliente         Cliente     @relation(fields: [clienteId], references: [id])
  clienteApp      ClienteApp? @relation(fields: [clienteAppId], references: [id])
  reservaOriginal Reserva?    @relation("Reagendamiento", fields: [reservaOriginalId], references: [id])
  reagendamientos Reserva[]   @relation("Reagendamiento")
  serviciosDetalle ReservaServicio[]

  @@index([personalId, fecha])
  @@index([estudioId, fecha])
  @@index([personalId, fecha, estado])
  @@index([estudioId, fecha, estado])
  @@index([clienteAppId])
  @@map("reservas")
}

model ReservaServicio {
  id        String   @id @default(cuid())
  reservaId String
  nombre    String
  duracion  Int
  precio    Int      @default(0)
  categoria String?
  orden     Int      @default(0)
  estado    String   @default("pending")
  motivo    String?
  creadoEn  DateTime @default(now())

  reserva   Reserva  @relation(fields: [reservaId], references: [id], onDelete: Cascade)

  @@index([reservaId, orden])
  @@map("reserva_servicios")
}

model Pago {
  id          String   @id @default(cuid())
  estudioId   String
  monto       Int
  moneda      String   @default("MXN")
  concepto    String
  fecha       String   // "YYYY-MM-DD"
  tipo        String   @default("suscripcion") // suscripcion | otro
  referencia  String?
  creadoEn    DateTime @default(now())

  estudio     Estudio  @relation(fields: [estudioId], references: [id], onDelete: Cascade)

  @@map("pagos")
}

model DiaFestivo {
  id          String   @id @default(cuid())
  estudioId   String
  fecha       String   // "YYYY-MM-DD"
  descripcion String   @default("")
  creadoEn    DateTime @default(now())

  estudio     Estudio  @relation(fields: [estudioId], references: [id], onDelete: Cascade)

  @@unique([estudioId, fecha])
  @@map("dias_festivos")
}

model Usuario {
  id              String        @id @default(uuid())
  email           String        @unique
  hashContrasena  String
  nombre          String        @default("")
  rol             RolUsuario    @default(dueno)
  porcentajeComision Int        @default(10)
  activo          Boolean       @default(true)
  emailVerificado Boolean       @default(false)
  estudioId       String?
  estudio         Estudio?      @relation(fields: [estudioId], references: [id])
  ultimoAcceso    DateTime?
  creadoEn        DateTime      @default(now())
  actualizadoEn   DateTime      @updatedAt

  tokensReset     TokenReset[]
  permisos        PermisosMaestro?
  permisosSupervisor PermisosSupervisor?
  auditLogs       AuditLog[]
  suscripcionesPush SuscripcionPush[]
  estudiosVendedor  Estudio[]    @relation("EstudioVendedor")
  preregistros      PreregistroSalon[]

  @@map("usuarios")
}

model SuscripcionPush {
  id         String     @id @default(uuid())
  endpoint   String     @unique
  p256dh     String
  auth       String
  tipo       String     // "cliente" | "dueno"
  usuarioId  String?
  clienteId  String?
  activa     Boolean    @default(true)
  creadoEn   DateTime   @default(now())

  usuario    Usuario?   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  clienteApp ClienteApp? @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@map("suscripciones_push")
  @@index([usuarioId])
  @@index([clienteId])
}

model TokenReset {
  id        String   @id @default(uuid())
  usuarioId String
  token     String   @unique
  expiraEn  DateTime
  usado     Boolean  @default(false)
  creadoEn  DateTime @default(now())

  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("tokens_reset")
}

model PermisosMaestro {
  id               String   @id @default(uuid())
  usuarioId        String   @unique
  usuario          Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  aprobarSalones   Boolean  @default(false)
  gestionarPagos   Boolean  @default(false)
  crearAdmins      Boolean  @default(false)
  verAuditLog      Boolean  @default(false)
  verMetricas      Boolean  @default(false)
  suspenderSalones Boolean  @default(false)
  esMaestroTotal   Boolean  @default(false)
  creadoEn         DateTime @default(now())
  actualizadoEn    DateTime @updatedAt

  @@map("permisos_maestro")
}

model MensajeMasivo {
  id          String   @id @default(uuid())
  estudioId   String
  estudio     Estudio  @relation(fields: [estudioId], references: [id], onDelete: Cascade)
  titulo      String
  texto       String   @db.VarChar(200)
  imagenUrl   String?
  fechaEnvio  DateTime
  enviado     Boolean  @default(false)
  creadoEn    DateTime @default(now())

  @@map("mensajes_masivos")
  @@index([estudioId])
}

model Producto {
  id          String   @id @default(uuid())
  estudioId   String
  estudio     Estudio  @relation(fields: [estudioId], references: [id], onDelete: Cascade)
  nombre      String
  categoria   String   @default("General")
  precio      Int      // centavos
  activo      Boolean  @default(true)
  creadoEn    DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@map("productos")
  @@index([estudioId])
}

model PermisosSupervisor {
  id                   String  @id @default(uuid())
  usuarioId            String  @unique
  usuario              Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  // Métricas
  verTotalSalones      Boolean @default(false)
  verControlSalones    Boolean @default(false)
  verReservas          Boolean @default(false)
  verVentas            Boolean @default(false)
  // Directorio
  verDirectorio        Boolean @default(false)
  editarDirectorio     Boolean @default(false)
  // Control de cobros
  verControlCobros     Boolean @default(false)
  accionRecordatorio   Boolean @default(false)
  accionRegistroPago   Boolean @default(false)
  accionSuspension     Boolean @default(false)
  // Vendedores
  activarSalones       Boolean @default(false)
  verPreregistros      Boolean @default(false)
  creadoEn             DateTime @default(now())
  actualizadoEn        DateTime @updatedAt

  @@map("permisos_supervisor")
}

model AuditLog {
  id          String   @id @default(uuid())
  usuarioId   String?
  usuario     Usuario? @relation(fields: [usuarioId], references: [id], onDelete: SetNull)
  accion      String
  entidadTipo String
  entidadId   String
  detalles    Json?
  ip          String?
  creadoEn    DateTime @default(now())

  @@map("audit_log")
  @@index([entidadId, creadoEn])
  @@index([usuarioId])
}

model NotificacionEstudio {
  id          String   @id @default(uuid())
  estudioId   String
  tipo        String   // 'recordatorio_pago' | 'pago_confirmado' | 'suspension'
  titulo      String
  mensaje     String   @db.Text
  leida       Boolean  @default(false)
  creadoEn    DateTime @default(now())

  estudio     Estudio  @relation(fields: [estudioId], references: [id], onDelete: Cascade)

  @@map("notificaciones_estudio")
  @@index([estudioId, leida])
}

