// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum EstadoSalon {
  pendiente
  aprobado
  rechazado
  suspendido
}

// ─────────────────────────────────────────
// Modelos de dominio — Beauty Time Pro
// ─────────────────────────────────────────

model Estudio {
  id                String       @id @default(cuid())
  nombre            String
  propietario       String
  telefono          String
  sitioWeb          String?
  pais              String       @default("Mexico")
  sucursales        Json         // string[]
  claveDueno        String       @unique
  claveCliente      String       @unique
  activo            Boolean      @default(true)
  estado            EstadoSalon  @default(pendiente)
  motivoRechazo     String?
  fechaSolicitud    DateTime     @default(now())
  fechaAprobacion   DateTime?
  suscripcion       String       @default("mensual")
  inicioSuscripcion String       // "YYYY-MM-DD"
  fechaVencimiento  String       // "YYYY-MM-DD"
  horario           Json         // Record<string, TurnoTrabajo>
  servicios         Json         // Servicio[]
  serviciosCustom   Json         // ServicioPersonalizado[]
  festivos          Json         // string[] fechas bloqueadas
  colorPrimario     String?      @default("#C2185B")
  logoUrl           String?
  descripcion       String?
  direccion         String?
  emailContacto     String?
  horarioApertura   String?      @default("09:00")
  horarioCierre     String?      @default("18:00")
  diasAtencion      String?      @default("lunes,martes,miercoles,jueves,viernes")
  numeroEspecialistas Int?       @default(1)
  categorias        String?
  primeraVez        Boolean      @default(true)
  cancelacionSolicitada     Boolean   @default(false)
  fechaSolicitudCancelacion DateTime?
  motivoCancelacion         String?
  creadoEn          DateTime     @default(now())
  actualizadoEn     DateTime     @updatedAt

  personal          Personal[]
  reservas          Reserva[]
  pagos             Pago[]
  diasFestivos      DiaFestivo[]
  usuarios          Usuario[]
  clientes          Cliente[]
  configFidelidad   ConfigFidelidad?
  puntosFidelidad   PuntosFidelidad[]

  @@map("estudios")
  @@index([estado, activo])
  @@index([pais, estado])
  @@index([fechaVencimiento])
}

model ClienteApp {
  id                String      @id @default(uuid())
  email             String      @unique
  emailPendiente    String?
  hashContrasena    String
  nombre            String
  apellido          String
  fechaNacimiento   DateTime
  pais              String      @default("Mexico")
  telefono          String?
  avatarUrl         String?
  emailVerificado   Boolean     @default(false)
  activo            Boolean     @default(true)
  ultimoAcceso      DateTime?
  creadoEn          DateTime    @default(now())
  actualizadoEn     DateTime    @updatedAt

  tokens            TokenVerificacionApp[]
  reservas          Reserva[]
  suscripcionesPush SuscripcionPush[]

  @@map("clientes_app")
  @@index([pais])
}

model TokenVerificacionApp {
  id          String      @id @default(uuid())
  token       String      @unique @default(uuid())
  tipo        String      // "verificacion_email" | "reset_contrasena"
  usuarioId   String?
  clienteId   String?
  clienteApp  ClienteApp? @relation(fields: [clienteId], references: [id])
  expiraEn    DateTime
  usado       Boolean     @default(false)
  creadoEn    DateTime    @default(now())

  @@map("tokens_verificacion_app")
}

model Personal {
  id             String    @id @default(cuid())
  estudioId      String
  nombre         String
  avatarUrl      String?
  especialidades Json      // string[]
  activo         Boolean   @default(true)
  horaInicio     String?   // "HH:mm"
  horaFin        String?   // "HH:mm"
  descansoInicio String?   // "HH:mm"
  descansoFin    String?   // "HH:mm"
  diasTrabajo    Json?     // number[] (0=Dom…6=Sab) | null usa horario del estudio
  creadoEn       DateTime  @default(now())

  estudio        Estudio        @relation(fields: [estudioId], references: [id], onDelete: Cascade)
  reservas       Reserva[]
  acceso         EmpleadoAcceso?

  @@map("personal")
  @@index([estudioId, activo])
}

model EmpleadoAcceso {
  id             String    @id @default(uuid())
  personalId     String    @unique
  personal       Personal  @relation(fields: [personalId], references: [id], onDelete: Cascade)
  email          String    @unique
  hashContrasena String
  forzarCambioContrasena Boolean @default(false)
  activo         Boolean   @default(true)
  ultimoAcceso   DateTime?
  creadoEn       DateTime  @default(now())
  actualizadoEn  DateTime  @updatedAt

  @@map("empleados_acceso")
}

model Cliente {
  id              String    @id @default(uuid())
  estudioId       String
  estudio         Estudio   @relation(fields: [estudioId], references: [id], onDelete: Cascade)
  nombre          String
  telefono        String
  fechaNacimiento DateTime
  email           String?
  notas           String?   @db.Text
  activo          Boolean   @default(true)
  creadoEn        DateTime  @default(now())
  actualizadoEn   DateTime  @updatedAt

  reservas        Reserva[]
  puntosFidelidad PuntosFidelidad[]

  @@unique([estudioId, telefono])
  @@map("clientes")
}

model ConfigFidelidad {
  id                     String   @id @default(uuid())
  estudioId              String   @unique
  estudio                Estudio  @relation(fields: [estudioId], references: [id], onDelete: Cascade)
  activo                 Boolean  @default(false)
  visitasRequeridas      Int      @default(5)
  tipoRecompensa         String   @default("descuento") // descuento | servicio_gratis
  porcentajeDescuento    Int?     @default(100)
  descripcionRecompensa  String   @default("Servicio gratis en tu próxima visita")
  creadoEn               DateTime @default(now())
  actualizadoEn          DateTime @updatedAt

  @@map("config_fidelidad")
}

model PuntosFidelidad {
  id                  String   @id @default(uuid())
  clienteId           String
  cliente             Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  estudioId           String
  estudio             Estudio  @relation(fields: [estudioId], references: [id], onDelete: Cascade)
  visitasAcumuladas   Int      @default(0)
  visitasUsadas       Int      @default(0)
  recompensasGanadas  Int      @default(0)
  recompensasUsadas   Int      @default(0)
  ultimaVisita        DateTime?
  creadoEn            DateTime @default(now())
  actualizadoEn       DateTime @updatedAt

  @@unique([clienteId, estudioId])
  @@map("puntos_fidelidad")
}

model Reserva {
  id              String   @id @default(cuid())
  estudioId       String
  personalId      String
  clienteId       String
  nombreCliente   String
  telefonoCliente String
  fecha           String   // "YYYY-MM-DD"
  horaInicio      String   // "HH:mm"
  duracion        Int      // minutos
  servicios       Json     // Servicio[]
  precioTotal     Float    @default(0)
  estado          String   @default("pending") // pending | confirmed | completed | cancelled
  sucursal        String   @default("")
  marcaTinte      String?
  tonalidad       String?
  notasMenorEdad  String?
  clienteAppId    String?
  recordatorioEnviado Boolean @default(false)
  tokenCancelacion String @unique @default(uuid())
  creadoEn        DateTime @default(now())

  estudio         Estudio     @relation(fields: [estudioId], references: [id], onDelete: Cascade)
  empleado        Personal    @relation(fields: [personalId], references: [id])
  cliente         Cliente     @relation(fields: [clienteId], references: [id])
  clienteApp      ClienteApp? @relation(fields: [clienteAppId], references: [id])

  @@index([personalId, fecha])
  @@index([estudioId, fecha])
  @@index([clienteAppId])
  @@map("reservas")
}

model Pago {
  id          String   @id @default(cuid())
  estudioId   String
  monto       Float
  moneda      String   @default("MXN")
  concepto    String
  fecha       String   // "YYYY-MM-DD"
  tipo        String   @default("suscripcion") // suscripcion | otro
  referencia  String?
  creadoEn    DateTime @default(now())

  estudio     Estudio  @relation(fields: [estudioId], references: [id], onDelete: Cascade)

  @@map("pagos")
}

model DiaFestivo {
  id          String   @id @default(cuid())
  estudioId   String
  fecha       String   // "YYYY-MM-DD"
  descripcion String   @default("")
  creadoEn    DateTime @default(now())

  estudio     Estudio  @relation(fields: [estudioId], references: [id], onDelete: Cascade)

  @@unique([estudioId, fecha])
  @@map("dias_festivos")
}

model Usuario {
  id              String        @id @default(uuid())
  email           String        @unique
  hashContrasena  String
  nombre          String        @default("")
  rol             String        // "maestro" | "dueno"
  activo          Boolean       @default(true)
  emailVerificado Boolean       @default(false)
  estudioId       String?
  estudio         Estudio?      @relation(fields: [estudioId], references: [id])
  ultimoAcceso    DateTime?
  creadoEn        DateTime      @default(now())
  actualizadoEn   DateTime      @updatedAt

  tokensReset     TokenReset[]
  permisos        PermisosMaestro?
  auditLogs       AuditLog[]
  suscripcionesPush SuscripcionPush[]

  @@map("usuarios")
}

model SuscripcionPush {
  id         String     @id @default(uuid())
  endpoint   String     @unique
  p256dh     String
  auth       String
  tipo       String     // "cliente" | "dueno"
  usuarioId  String?
  clienteId  String?
  activa     Boolean    @default(true)
  creadoEn   DateTime   @default(now())

  usuario    Usuario?   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  clienteApp ClienteApp? @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@map("suscripciones_push")
  @@index([usuarioId])
  @@index([clienteId])
}

model TokenReset {
  id        String   @id @default(uuid())
  usuarioId String
  token     String   @unique
  expiraEn  DateTime
  usado     Boolean  @default(false)
  creadoEn  DateTime @default(now())

  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("tokens_reset")
}

model PermisosMaestro {
  id               String   @id @default(uuid())
  usuarioId        String   @unique
  usuario          Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  aprobarSalones   Boolean  @default(false)
  gestionarPagos   Boolean  @default(false)
  crearAdmins      Boolean  @default(false)
  verAuditLog      Boolean  @default(false)
  verMetricas      Boolean  @default(false)
  suspenderSalones Boolean  @default(false)
  esMaestroTotal   Boolean  @default(false)
  creadoEn         DateTime @default(now())
  actualizadoEn    DateTime @updatedAt

  @@map("permisos_maestro")
}

model AuditLog {
  id          String   @id @default(uuid())
  usuarioId   String
  usuario     Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  accion      String
  entidadTipo String
  entidadId   String
  detalles    Json?
  ip          String?
  creadoEn    DateTime @default(now())

  @@map("audit_log")
  @@index([entidadId, creadoEn])
  @@index([usuarioId])
}

