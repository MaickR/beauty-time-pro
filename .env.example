# Beauty Time Pro — Variables de entorno
# Copia este archivo a .env y completa los valores reales.
# NUNCA subas .env al repositorio.
# ─────────────────────────────────────────────

# Base de datos
DATABASE_URL=mysql://usuario:contraseña@host:3306/beauty_time_pro

# JWT
JWT_SECRETO=
JWT_EXPIRA_EN=15m
JWT_REFRESH_EXPIRA_EN=7d
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_REMITENTE=notificaciones@beautytimepro.com
FRONTEND_URL=http://localhost:5173
ADMINS_PROTEGIDOS=miguel@beautytimepro.com,dev@beautytimepro.com

# Servidor
PUERTO=3000
ENTORNO=development

# Frontend
VITE_URL_API=http://localhost:3000
