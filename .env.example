# ─────────────────────────────────────────────────────────────────
# Beauty Time Pro — Variables de entorno del FRONTEND (Vite/React)
# Copia este archivo a .env.local y completa los valores.
# NUNCA subas .env.local al repositorio.
#
# Las variables del servidor (DATABASE_URL, JWT_SECRETO, VAPID, etc.)
# están documentadas en server/.env.example
# ─────────────────────────────────────────────────────────────────

# URL base de la API del servidor
VITE_URL_API=http://localhost:3000

# URL publica del frontend para enlaces compartidos, QR y reservas.
# En Vercel produccion usa el dominio oficial: https://salonpromaster.com
# En previews puedes omitirla para usar el origen actual del deploy.
VITE_URL_PUBLICA=http://localhost:5173

